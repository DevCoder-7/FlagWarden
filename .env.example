APP_ENV=local
APP_NAME=FlagWarden
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./ctf_bot.db
CHALLENGE_DATA_PATH=data/challenges.json
BOT_TEST_MODE=true

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token

# Optional LLM integration
LLM_PROVIDER=none
LLM_API_KEY=replace-me-only-if-provider-is-enabled

INPUT_MAX_LENGTH=2000
ANSWER_RATE_LIMIT_COUNT=5
ANSWER_RATE_LIMIT_WINDOW_SECONDS=60
