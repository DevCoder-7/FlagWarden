APP_ENV=local
APP_NAME=FlagWarden
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./ctf_bot.db
CHALLENGE_DATA_PATH=data/challenges.json
BOT_TEST_MODE=true

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-local-token
WHATSAPP_ACCESS_TOKEN=replace-with-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
WHATSAPP_API_VERSION=v20.0

# Optional LLM integration
LLM_PROVIDER=none
LLM_API_KEY=replace-me-only-if-provider-is-enabled

INPUT_MAX_LENGTH=2000
ANSWER_RATE_LIMIT_COUNT=5
ANSWER_RATE_LIMIT_WINDOW_SECONDS=60